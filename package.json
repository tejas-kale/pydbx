{
  "name": "pydbx",
  "displayName": "Databricks Local Notebooks",
  "description": "Open Databricks-format .py files as notebooks in VS Code",
  "version": "0.0.1",
  "publisher": "your-publisher",
  "repository": {
    "type": "git",
    "url": "https://github.com/tejas-kale/pydbx"
  },
  "engines": {
    "vscode": "^1.65.0"
  },
  "extensionDependencies": [
    "ms-python.python"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "scripts": {
    "compile": "tsc -p ./",
    "test": "vitest run"
  },
  "contributes": {
    "commands": [
      {
        "command": "pydbx.restartKernel",
        "title": "Restart Kernel",
        "icon": "$(debug-restart)",
        "category": "Notebook"
      },
      {
        "command": "pydbx.interruptKernel",
        "title": "Interrupt Kernel",
        "icon": "$(debug-stop)",
        "category": "Notebook"
      }
    ],
    "menus": {
      "notebook/toolbar": [
        {
          "command": "pydbx.restartKernel",
          "group": "navigation",
          "when": "notebookType == 'databricks-notebook-local'"
        },
        {
          "command": "pydbx.interruptKernel",
          "group": "navigation",
          "when": "notebookType == 'databricks-notebook-local'"
        }
      ]
    },
    "notebooks": [
      {
        "type": "databricks-notebook-local",
        "displayName": "Databricks Local Notebooks",
        "selector": [
          {
            "filenamePattern": "*.py"
          }
        ]
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.65.0",
    "@vscode/vsce": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
